{
  "name": "@markdown-kit/service",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun dist/index.js --stdio",
    "dev": "bun --watch index.ts",
    "build": "bun build index.ts --outdir dist --target bun --minify",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/markdown-it": "^14.1.2",
    "typescript": "^5.9.3"
  }
}
